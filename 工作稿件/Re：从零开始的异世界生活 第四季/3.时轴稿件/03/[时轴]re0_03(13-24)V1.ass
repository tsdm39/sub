Comment: 0,0:13:03.05,0:13:04.76,对白 日语,,0,0,0,,part3
Dialogue: 0,0:13:04.76,0:13:05.88,对白 日语,Anastasia,0,0,0,,ナツキ君?
Dialogue: 1,0:13:04.76,0:13:05.88,对白 中文,Anastasia,0,0,0,,菜月？
Dialogue: 0,0:13:07.03,0:13:07.89,对白 日语,Anastasia,0,0,0,,どないしたん?
Dialogue: 1,0:13:07.03,0:13:07.89,对白 中文,Anastasia,0,0,0,,怎么了？
Dialogue: 0,0:13:09.37,0:13:09.96,对白 日语,Subaru,0,0,0,,いや
Dialogue: 1,0:13:09.37,0:13:09.96,对白 中文,Subaru,0,0,0,,不
Dialogue: 0,0:13:11.42,0:13:12.37,对白 日语,Subaru,0,0,0,,なんでもねえよ
Dialogue: 1,0:13:11.42,0:13:12.37,对白 中文,Subaru,0,0,0,,没什么
Dialogue: 0,0:13:16.59,0:13:17.40,对白 日语,Anastasia,0,0,0,,そしたら
Dialogue: 1,0:13:16.59,0:13:17.40,对白 中文,Anastasia,0,0,0,,既然如此
Dialogue: 0,0:13:34.15,0:13:36.07,对白 日语,Subaru,0,0,0,,離せ!離せ~!!
Dialogue: 1,0:13:34.15,0:13:36.07,对白 中文,Subaru,0,0,0,,放开我!放开我~!!
Dialogue: 0,0:13:36.69,0:13:40.32,对白 日语,Anastasia,0,0,0,,嫌や!うち 死にたない
Dialogue: 1,0:13:36.69,0:13:40.32,对白 中文,Anastasia,0,0,0,,不要!伦家不想死
Dialogue: 0,0:13:40.38,0:13:44.40,对白 日语,Subaru,0,0,0,,もう死んでんだよ 助かるわけねえだろ
Dialogue: 1,0:13:40.38,0:13:44.40,对白 中文,Subaru,0,0,0,,你已经死了啊 怎么可能救得回来
Dialogue: 0,0:13:44.40,0:13:46.30,对白 日语,Subaru,0,0,0,,この ばか くそが
Dialogue: 1,0:13:44.40,0:13:46.30,对白 中文,Subaru,0,0,0,,你这个笨蛋 混账东西
Dialogue: 0,0:13:46.90,0:13:49.01,对白 日语,Subaru,0,0,0,,とっとと死ねよ
Dialogue: 1,0:13:46.90,0:13:49.01,对白 中文,Subaru,0,0,0,,赶紧去死吧
Dialogue: 0,0:14:10.68,0:14:13.74,对白 日语,Anastasia,0,0,0,,置いて かないで
Dialogue: 1,0:14:10.68,0:14:13.74,对白 中文,Anastasia,0,0,0,,别丢下我
Dialogue: 0,0:14:22.92,0:14:25.68,对白 日语,Subaru,0,0,0,,ラムだ ラムの魔法だ
Dialogue: 1,0:14:22.92,0:14:25.68,对白 中文,Subaru,0,0,0,,是拉姆 是拉姆的魔法
Dialogue: 0,0:14:25.99,0:14:28.82,对白 日语,Subaru,0,0,0,,あのくそ女 生きてやがった
Dialogue: 1,0:14:25.99,0:14:28.82,对白 中文,Subaru,0,0,0,,那个臭女人 竟然还活着
Dialogue: 0,0:14:37.04,0:14:38.04,对白 日语,Subaru,0,0,0,,パトラッシュ
Dialogue: 1,0:14:37.04,0:14:38.04,对白 中文,Subaru,0,0,0,,帕特拉修
Dialogue: 0,0:14:39.02,0:14:40.68,对白 日语,Subaru,0,0,0,,お前は無事だったのか
Dialogue: 1,0:14:39.02,0:14:40.68,对白 中文,Subaru,0,0,0,,你平安无事啊
Dialogue: 0,0:14:41.83,0:14:43.38,对白 日语,Subaru,0,0,0,,ラムは死んだのか
Dialogue: 1,0:14:41.83,0:14:43.38,对白 中文,Subaru,0,0,0,,拉姆死了吗
Dialogue: 0,0:14:44.84,0:14:45.72,对白 日语,Subaru,0,0,0,,いや いい
Dialogue: 1,0:14:44.84,0:14:45.72,对白 中文,Subaru,0,0,0,,不 算了
Dialogue: 0,0:14:46.21,0:14:47.24,对白 日语,Subaru,0,0,0,,乗せてくれ
Dialogue: 1,0:14:46.21,0:14:47.24,对白 中文,Subaru,0,0,0,,让我骑上去
Dialogue: 0,0:14:48.72,0:14:50.97,对白 日语,Subaru,0,0,0,,聞いてんのか おい
Dialogue: 1,0:14:48.72,0:14:50.97,对白 中文,Subaru,0,0,0,,喂 你听见没
Dialogue: 0,0:14:50.97,0:14:53.22,对白 日语,Subaru,0,0,0,,こっち来い この野郎
Dialogue: 1,0:14:50.97,0:14:53.22,对白 中文,Subaru,0,0,0,,给我过来 你这混蛋
Dialogue: 0,0:14:53.22,0:14:55.38,对白 日语,Subaru,0,0,0,,俺をなんだと思ってやがる
Dialogue: 1,0:14:53.22,0:14:55.38,对白 中文,Subaru,0,0,0,,你以为我是谁啊
Dialogue: 0,0:15:00.75,0:15:02.82,对白 日语,Subaru,0,0,0,,こいつやっと人の話を…
Dialogue: 1,0:15:00.75,0:15:02.82,对白 中文,Subaru,0,0,0,,这家伙终于肯听人说话了…
Dialogue: 0,0:15:31.76,0:15:33.32,对白 日语,Ram,0,0,0,,バルス バルス
Dialogue: 1,0:15:31.76,0:15:33.32,对白 中文,Ram,0,0,0,,巴鲁斯 巴鲁斯
Dialogue: 0,0:15:34.25,0:15:36.77,对白 日语,Ram,0,0,0,,いいかげん起きないと まぶたを焼き切るわよ
Dialogue: 1,0:15:34.25,0:15:36.77,对白 中文,Ram,0,0,0,,再不起来 就把你眼皮烧掉哦
Dialogue: 0,0:15:41.44,0:15:42.21,对白 日语,Subaru,0,0,0,,俺は…
Dialogue: 1,0:15:41.44,0:15:42.21,对白 中文,Subaru,0,0,0,,我…
Dialogue: 0,0:15:43.85,0:15:44.49,对白 日语,Ram,0,0,0,,バルス
Dialogue: 1,0:15:43.85,0:15:44.49,对白 中文,Ram,0,0,0,,巴鲁斯
Dialogue: 0,0:15:47.52,0:15:48.63,对白 日语,Ram,0,0,0,,情けないわね
Dialogue: 1,0:15:47.52,0:15:48.63,对白 中文,Ram,0,0,0,,真没出息呢
Dialogue: 0,0:15:50.11,0:15:50.94,对白 日语,Ram,0,0,0,,かむんじゃないわよ
Dialogue: 1,0:15:50.11,0:15:50.94,对白 中文,Ram,0,0,0,,别咬我手哦
Dialogue: 0,0:15:57.95,0:15:59.92,对白 日语,Subaru,0,0,0,,悪い もう大丈夫
Dialogue: 1,0:15:57.95,0:15:59.92,对白 中文,Subaru,0,0,0,,抱歉 我已经没事了
Dialogue: 0,0:16:00.33,0:16:03.46,对白 日语,Ram,0,0,0,,そう 満足できたみたいでよかったでちゅね
Dialogue: 1,0:16:00.33,0:16:03.46,对白 中文,Ram,0,0,0,,是吗 看来你已经心满意足了呢
Dialogue: 0,0:16:03.96,0:16:05.46,对白 日语,Subaru,0,0,0,,お前な…
Dialogue: 1,0:16:03.96,0:16:05.46,对白 中文,Subaru,0,0,0,,你啊…
Dialogue: 0,0:16:05.67,0:16:06.88,对白 日语,Anastasia,0,0,0,,よかったわ
Dialogue: 1,0:16:05.67,0:16:06.88,对白 中文,Anastasia,0,0,0,,太好了
Dialogue: 0,0:16:07.17,0:16:09.56,对白 日语,Anastasia,0,0,0,,ナツキ君も目ぇ覚めたみたいやね
Dialogue: 1,0:16:07.17,0:16:09.56,对白 中文,Anastasia,0,0,0,,看来菜月也醒了呢
Dialogue: 0,0:16:10.43,0:16:12.99,对白 日语,Ram,0,0,0,,おかげさまで 周囲はどうでしたか
Dialogue: 1,0:16:10.43,0:16:12.99,对白 中文,Ram,0,0,0,,托您的福 周围情况怎么样
Dialogue: 0,0:16:13.26,0:16:17.52,对白 日语,Anastasia,0,0,0,,あかんね 近くには出口も他の子らも見当たらへん
Dialogue: 1,0:16:13.26,0:16:17.52,对白 中文,Anastasia,0,0,0,,不行呢 附近没看到有出口和其他人
Dialogue: 0,0:16:17.98,0:16:19.18,对白 日语,Anastasia,0,0,0,,ナツキ君?
Dialogue: 1,0:16:17.98,0:16:19.18,对白 中文,Anastasia,0,0,0,,菜月?
Dialogue: 0,0:16:20.44,0:16:21.50,对白 日语,Anastasia,0,0,0,,どないしたん?
Dialogue: 1,0:16:20.44,0:16:21.50,对白 中文,Anastasia,0,0,0,,怎么了?
Dialogue: 0,0:16:22.60,0:16:25.90,对白 日语,Subaru,0,0,0,,なあ 瘴気ってのは一体なんなんだ
Dialogue: 1,0:16:22.60,0:16:25.90,对白 中文,Subaru,0,0,0,,我说 瘴气到底是个什么东西
Dialogue: 0,0:16:27.11,0:16:29.12,对白 日语,Subaru,0,0,0,,ここも砂丘の一部なんだろ?
Dialogue: 1,0:16:27.11,0:16:29.12,对白 中文,Subaru,0,0,0,,这里也是沙丘的一部分吧?
Dialogue: 0,0:16:29.73,0:16:32.28,对白 日语,Subaru,0,0,0,,瘴気が漂ってるって話だったよな?
Dialogue: 1,0:16:29.73,0:16:32.28,对白 中文,Subaru,0,0,0,,之前说这里弥漫着瘴气吧?
Dialogue: 0,0:16:32.84,0:16:35.98,对白 日语,Ram,0,0,0,,瘴気というのは 要は汚染されたマナのことよ
Dialogue: 1,0:16:32.84,0:16:35.98,对白 中文,Ram,0,0,0,,所谓的瘴气 说白了就是被污染的玛娜
Dialogue: 0,0:16:36.24,0:16:37.85,对白 日语,Subaru,0,0,0,,汚染されたマナ?
Dialogue: 1,0:16:36.24,0:16:37.85,对白 中文,Subaru,0,0,0,,被污染的玛娜?
Dialogue: 0,0:16:37.99,0:16:41.94,对白 日语,Anastasia,0,0,0,,放っておくと 身も心もむしばまれるって話やけど
Dialogue: 1,0:16:37.99,0:16:41.94,对白 中文,Anastasia,0,0,0,,听说放任不管的话 身心都会被侵蚀
Dialogue: 0,0:16:42.50,0:16:43.34,对白 日语,Subaru,0,0,0,,対応策は?
Dialogue: 1,0:16:42.50,0:16:43.34,对白 中文,Subaru,0,0,0,,有什么对策吗?
Dialogue: 0,0:16:43.75,0:16:48.35,对白 日语,Anastasia,0,0,0,,うちらのゲートが マナを取り込むこと自体は自然なことやから
Dialogue: 1,0:16:43.75,0:16:48.35,对白 中文,Anastasia,0,0,0,,因为我们的门吸收玛娜本身就是自然现象
Dialogue: 0,0:16:48.88,0:16:53.78,对白 日语,Anastasia,0,0,0,,できるとしたら 瘴気の濃いとこに近づかないようにするだけ やね
Dialogue: 1,0:16:48.88,0:16:53.78,对白 中文,Anastasia,0,0,0,,所以能做的 也就只有尽量不靠近瘴气浓的地方了
Dialogue: 0,0:16:56.22,0:16:58.08,对白 日语,Subaru,0,0,0,,あれが瘴気の影響
Dialogue: 1,0:16:56.22,0:16:58.08,对白 中文,Subaru,0,0,0,,那是瘴气的影响
Dialogue: 0,0:16:58.35,0:17:00.86,对白 日语,Subaru,0,0,0,,なら この先進んだらまた…
Dialogue: 1,0:16:58.35,0:17:00.86,对白 中文,Subaru,0,0,0,,那么 再往前走的话又会…
Dialogue: 0,0:17:01.22,0:17:02.08,对白 日语,Subaru,0,0,0,,いや
Dialogue: 1,0:17:01.22,0:17:02.08,对白 中文,Subaru,0,0,0,,不
Dialogue: 0,0:17:05.94,0:17:06.60,对白 日语,Ram,0,0,0,,バルス?
Dialogue: 1,0:17:05.94,0:17:06.60,对白 中文,Ram,0,0,0,,巴鲁斯?
Dialogue: 0,0:17:07.27,0:17:08.08,对白 日语,Subaru,0,0,0,,行こう
Dialogue: 1,0:17:07.27,0:17:08.08,对白 中文,Subaru,0,0,0,,我们走吧
Dialogue: 0,0:17:19.49,0:17:21.46,对白 日语,Subaru,0,0,0,,左だ 左に進もう
Dialogue: 1,0:17:19.49,0:17:21.46,对白 中文,Subaru,0,0,0,,左边 往左边走吧
Dialogue: 0,0:17:26.21,0:17:28.82,对白 日语,Subaru,0,0,0,,アナスタシアさん ここ天井低いから
Dialogue: 1,0:17:26.08,0:17:28.82,对白 中文,Subaru,0,0,0,,安娜塔西亚小姐 这里天花板很低
Dialogue: 0,0:17:28.82,0:17:29.74,对白 日语,Subaru,0,0,0,,気を付けてくれ
Dialogue: 1,0:17:28.82,0:17:29.74,对白 中文,Subaru,0,0,0,,要小心
Dialogue: 0,0:17:30.05,0:17:32.24,对白 日语,Anastasia,0,0,0,,うん わかったわ ありがと
Dialogue: 1,0:17:30.05,0:17:32.24,对白 中文,Anastasia,0,0,0,,嗯 我知道了 谢谢
Dialogue: 0,0:17:32.84,0:17:35.24,对白 日语,Subaru,0,0,0,,ラム ちょっと足場が悪いぞ
Dialogue: 1,0:17:32.84,0:17:35.24,对白 中文,Subaru,0,0,0,,拉姆 这里的路不太好走
Dialogue: 0,0:17:35.60,0:17:36.39,对白 日语,Subaru,0,0,0,,注意してくれ
Dialogue: 1,0:17:35.60,0:17:36.39,对白 中文,Subaru,0,0,0,,注意点
Dialogue: 0,0:17:36.92,0:17:38.36,对白 日语,Ram,0,0,0,,ええ わかったわ
Dialogue: 1,0:17:36.92,0:17:38.36,对白 中文,Ram,0,0,0,,好的 我知道了
Dialogue: 0,0:17:38.36,0:17:40.44,对白 日语,Subaru,0,0,0,,寒かったらすぐ言えよ
Dialogue: 1,0:17:38.36,0:17:40.44,对白 中文,Subaru,0,0,0,,如果觉得冷就马上说哦
Dialogue: 0,0:17:40.84,0:17:42.50,对白 日语,Subaru,0,0,0,,俺のマントでよければ 貸すから
Dialogue: 1,0:17:40.84,0:17:42.50,对白 中文,Subaru,0,0,0,,不介意的话 我的斗篷可以借给你
Dialogue: 0,0:17:43.97,0:17:46.34,对白 日语,Subaru,0,0,0,,なっ… なんだよ?どうしたんだ
Dialogue: 1,0:17:43.97,0:17:46.34,对白 中文,Subaru,0,0,0,,怎…怎么了?发生什么事了
Dialogue: 0,0:17:46.85,0:17:47.82,对白 日语,Ram,0,0,0,,そっちこそ
Dialogue: 1,0:17:46.85,0:17:47.82,对白 中文,Ram,0,0,0,,你才是
Dialogue: 0,0:17:48.19,0:17:50.34,对白 日语,Ram,0,0,0,,その薄気味悪い気遣いはなんなの
Dialogue: 1,0:17:48.19,0:17:50.34,对白 中文,Ram,0,0,0,,你那毛骨悚然的关心是怎么回事
Dialogue: 0,0:17:50.86,0:17:51.98,对白 日语,Ram,0,0,0,,なんのたくらみがあるの?
Dialogue: 1,0:17:50.86,0:17:51.98,对白 中文,Ram,0,0,0,,你在打什么算盘?
Dialogue: 0,0:17:52.23,0:17:54.10,对白 日语,Subaru,0,0,0,,なんも たくらんじゃいねえよ
Dialogue: 1,0:17:52.23,0:17:54.10,对白 中文,Subaru,0,0,0,,我什么算盘都没打
Dialogue: 0,0:17:54.36,0:17:58.46,对白 日语,Subaru,0,0,0,,ただ 俺はお前たちに健やかでいてほしいだけで
Dialogue: 1,0:17:54.36,0:17:58.46,对白 中文,Subaru,0,0,0,,我只是 希望你们都能好好的而已
Dialogue: 0,0:17:58.46,0:17:59.10,对白 日语,Ram,0,0,0,,嫌らしい
Dialogue: 1,0:17:58.46,0:17:59.10,对白 中文,Ram,0,0,0,,真下流
Dialogue: 0,0:17:59.16,0:18:00.71,对白 日语,Subaru,0,0,0,,嫌らしくねえよ
Dialogue: 1,0:17:59.16,0:18:00.71,对白 中文,Subaru,0,0,0,,一点也不下流
Dialogue: 0,0:18:01.12,0:18:03.71,对白 日语,Subaru,0,0,0,,別にやってることユリウスと変わんねえだろ
Dialogue: 1,0:18:01.12,0:18:03.71,对白 中文,Subaru,0,0,0,,我做的事跟由里乌斯没什么区别吧
Dialogue: 0,0:18:03.71,0:18:06.67,对白 日语,Anastasia,0,0,0,,やって ユリウスは自然やけど
Dialogue: 1,0:18:03.71,0:18:06.67,对白 中文,Anastasia,0,0,0,,可是 由里乌斯这么做很自然
Dialogue: 0,0:18:06.67,0:18:09.97,对白 日语,Anastasia,0,0,0,,ナツキ君のは不健全?不自然やし
Dialogue: 1,0:18:06.67,0:18:09.97,对白 中文,Anastasia,0,0,0,,菜月你这样就是不健全?不自然啊
Dialogue: 0,0:18:09.97,0:18:11.02,对白 日语,Subaru,0,0,0,,不健全って言った!?
Dialogue: 1,0:18:09.97,0:18:11.02,对白 中文,Subaru,0,0,0,,你刚刚说我不健全?!
Dialogue: 0,0:18:14.34,0:18:16.86,对白 日语,Anastasia,0,0,0,,なんや 変なにおいがしてこうへん
Dialogue: 1,0:18:14.34,0:18:16.86,对白 中文,Anastasia,0,0,0,,什么情况 是不是有股奇怪的味道
Dialogue: 0,0:18:17.34,0:18:19.48,对白 日语,Ram,0,0,0,,何かが燃えてるにおいね
Dialogue: 1,0:18:17.34,0:18:19.48,对白 中文,Ram,0,0,0,,是什么东西烧焦的味道呢
Dialogue: 0,0:18:19.97,0:18:20.57,对白 日语,Subaru,0,0,0,,におい?
Dialogue: 1,0:18:19.97,0:18:20.57,对白 中文,Subaru,0,0,0,,味道?
Dialogue: 0,0:18:21.10,0:18:22.30,对白 日语,Subaru,0,0,0,,俺が見てくる
Dialogue: 1,0:18:21.10,0:18:22.30,对白 中文,Subaru,0,0,0,,我去看看
Dialogue: 0,0:18:24.47,0:18:26.78,对白 日语,Ram,0,0,0,,何かあったら バルスをおとりにするわ
Dialogue: 1,0:18:24.47,0:18:26.78,对白 中文,Ram,0,0,0,,要是发生了什么 就把巴鲁斯当诱饵
Dialogue: 0,0:18:27.22,0:18:28.45,对白 日语,Ram,0,0,0,,恨まないようになさい
Dialogue: 1,0:18:27.22,0:18:28.45,对白 中文,Ram,0,0,0,,你可别记恨
Dialogue: 0,0:18:28.45,0:18:30.42,对白 日语,Subaru,0,0,0,,そのときは呪わせてくれ
Dialogue: 1,0:18:28.45,0:18:30.42,对白 中文,Subaru,0,0,0,,到那时候就让我诅咒你吧
Dialogue: 0,0:18:53.63,0:18:55.23,对白 日语,Subaru,0,0,0,,ちょちょちょちょちょちょちょ
Dialogue: 1,0:18:53.63,0:18:55.23,对白 中文,Subaru,0,0,0,,等等等等等等等
Dialogue: 0,0:19:55.19,0:19:55.78,对白 日语,Ram,0,0,0,,ばか
Dialogue: 1,0:19:55.19,0:19:55.78,对白 中文,Ram,0,0,0,,笨蛋
Dialogue: 0,0:20:15.46,0:20:16.51,对白 日语,Ram,0,0,0,,エル·フーラ
Dialogue: 1,0:20:15.46,0:20:16.51,对白 中文,Ram,0,0,0,,埃尔·芙拉
Dialogue: 0,0:20:19.57,0:20:21.68,对白 日语,Ram,0,0,0,,立ちなさい レムが泣くわ
Dialogue: 1,0:20:19.57,0:20:21.68,对白 中文,Ram,0,0,0,,站起来 雷姆会哭的
Dialogue: 0,0:20:23.18,0:20:25.03,对白 日语,Ram,0,0,0,,死ぬんじゃない バルス
Dialogue: 1,0:20:23.18,0:20:25.03,对白 中文,Ram,0,0,0,,别死啊 巴鲁斯
Dialogue: 0,0:20:31.81,0:20:34.28,对白 日语,Subaru,0,0,0,,インビジブルプロヴィデンス
Dialogue: 1,0:20:31.81,0:20:34.28,对白 中文,Subaru,0,0,0,,不可视之神意
Dialogue: 0,0:20:35.33,0:20:36.96,对白 日语,Ram,0,0,0,,エル·フーラ
Dialogue: 1,0:20:35.33,0:20:36.96,对白 中文,Ram,0,0,0,,埃尔·芙拉
Dialogue: 0,0:20:44.79,0:20:45.39,对白 日语,Ram,0,0,0,,バルス
Dialogue: 1,0:20:44.79,0:20:45.39,对白 中文,Ram,0,0,0,,巴鲁斯
Dialogue: 0,0:21:07.09,0:21:08.87,对白 日语,Subaru,0,0,0,,どうして…
Dialogue: 1,0:21:07.09,0:21:08.87,对白 中文,Subaru,0,0,0,,为什么…
Dialogue: 0,0:21:10.51,0:21:12.30,对白 日语,Ram,0,0,0,,レムが泣くもの
Dialogue: 1,0:21:10.51,0:21:12.30,对白 中文,Ram,0,0,0,,因为雷姆会哭的
Dialogue: 0,0:21:18.73,0:21:20.30,对白 日语,Subaru,0,0,0,,動け ばか
Dialogue: 1,0:21:18.73,0:21:20.30,对白 中文,Subaru,0,0,0,,动起来 笨蛋
Dialogue: 0,0:21:21.02,0:21:22.63,对白 日语,Subaru,0,0,0,,寝てる場合か
Dialogue: 1,0:21:21.02,0:21:22.63,对白 中文,Subaru,0,0,0,,现在可不是睡觉的时候
Dialogue: 0,0:21:26.34,0:21:30.99,对白 日语,Subaru,0,0,0,,立て…立て!ナツキ·スバル!
Dialogue: 1,0:21:26.34,0:21:30.99,对白 中文,Subaru,0,0,0,,站起来…站起来!菜月昴!
Dialogue: 0,0:21:47.55,0:21:48.73,对白 日语,Subaru,0,0,0,,ラム
Dialogue: 1,0:21:47.55,0:21:48.73,对白 中文,Subaru,0,0,0,,拉姆
Dialogue: 0,0:22:08.10,0:22:10.01,对白 日语,Shaula,0,0,0,,見つけた
Dialogue: 1,0:22:08.10,0:22:10.01,对白 中文,Shaula,0,0,0,,找到你了
Dialogue: 1,0:22:07.86,0:22:10.01,场面文本,Title,0,0,0,,{\fad(1300,0)\pos(960,800)}监视塔的守卫
