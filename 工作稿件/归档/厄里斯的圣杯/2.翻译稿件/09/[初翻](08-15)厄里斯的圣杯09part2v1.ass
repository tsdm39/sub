Dialogue: 0,0:08:29.95,0:08:31.75,对白 日语,Aliénore,0,0,0,,
Dialogue: 1,0:08:29.95,0:08:31.75,对白 中文,Aliénore,0,0,0,,
Dialogue: 0,0:08:33.18,0:08:36.08,对白 日语,Aliénore,0,0,0,,
Dialogue: 1,0:08:33.18,0:08:36.08,对白 中文,Aliénore,0,0,0,,
Dialogue: 0,0:08:37.32,0:08:42.30,对白 日语,Aliénore,0,0,0,,
Dialogue: 1,0:08:37.32,0:08:42.30,对白 中文,Aliénore,0,0,0,,
Dialogue: 0,0:08:42.30,0:08:45.43,对白 日语,Aliénore,0,0,0,,
